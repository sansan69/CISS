rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read access for all employee-related files.
    // This is necessary for client-side PDF generation and public profiles.
    // Write access should be restricted to authenticated users (e.g., during enrollment).
    match /employees/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default Deny Rule for any other paths.
    // This is a security best practice.
    match /{path=**} {
       allow read, write: if false;
    }
  }
}
