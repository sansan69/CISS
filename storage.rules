rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAllowedSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isAllowedTrainingSize() {
      return request.resource.size < 100 * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isDocument() {
      return isImage() || request.resource.contentType == 'application/pdf';
    }

    function isTrainingContent() {
      return isImage()
        || request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.presentationml.presentation';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'superAdmin'
      );
    }

    function isFieldOfficer() {
      return isSignedIn() && request.auth.token.role == 'fieldOfficer';
    }

    // F-01: Field officer report photo uploads
    match /foReports/{folder}/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isFieldOfficer() && request.auth.uid == uid && isAllowedSize() && isImage();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/profilePictures/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isImage();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/signatures/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isImage();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/attendance/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isImage();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/idProofs/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isDocument();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/addressProofs/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isDocument();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/bankDocuments/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isDocument();
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeKey}/policeCertificates/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAllowedSize() && isDocument();
      allow update, delete: if isAdmin();
    }

    // Training module content — admin upload, signed-in read
    match /trainingModules/{fileName=**} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isAllowedTrainingSize() && isTrainingContent();
      allow delete: if isAdmin();
    }

    // Public self-enrollment uploads — unauthenticated writes allowed.
    // Admins can read and manage; anonymous users can only create (no overwrite/delete).
    match /enrollments/{allPaths=**} {
      allow read: if isSignedIn();
      allow create: if isAllowedSize() && isDocument();
      allow update, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
