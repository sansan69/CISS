rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the 'employees' collection
    match /employees/{employeeId} {
      
      // TEMPORARY: Allow all reads and writes to unblock functionality.
      // This is not secure for production and should be revisited.
      allow read, write: if true;

    }

    // Rules for the 'fieldOfficers' collection
    match /fieldOfficers/{officerId} {
      // Allow authenticated users to read their own Field Officer record
      // Admin (by email) can read/write all officer records
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        request.auth.token.email == 'admin@cisskerala.app'
      );
      allow create, update, delete: if request.auth != null && request.auth.token.email == 'admin@cisskerala.app';
    }

    // Rules for the 'workOrders' collection
    match /workOrders/{workOrderId} {
      // Allow authenticated users (admins/field officers) to read work orders
      allow read: if request.auth != null;
      // Restrict writes to admin
      allow create, update, delete: if request.auth != null && request.auth.token.email == 'admin@cisskerala.app';
    }

    // Rules for the 'sites' collection
    match /sites/{siteId} {
      // Allow authenticated users to read sites (used for imports and dashboards)
      allow read: if request.auth != null;
      // Restrict writes to admin
      allow create, update, delete: if request.auth != null && request.auth.token.email == 'admin@cisskerala.app';
    }

    // Rules for the 'clients' collection
    match /clients/{clientId} {

      // Allow anyone to read the list of clients. 
      // This is required for the client dropdown on the enrollment forms to work.
      allow read: if true;

      // Only allow admin to add, update, or delete clients.
      allow create, update, delete: if request.auth != null && request.auth.token.email == 'admin@cisskerala.app';
    }
  }
}
