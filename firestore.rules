rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.email == 'admin@cisskerala.app'
      );
    }

    function isFieldOfficer() {
      return isSignedIn() && request.auth.token.role == 'fieldOfficer';
    }

    function isClientUser() {
      return isSignedIn() && request.auth.token.role == 'client';
    }

    // NOTE: employees, clients, sites, and clientLocations intentionally allow
    // public reads. The attendance marking and employee enrollment flows are
    // unauthenticated (guards do not have auth accounts). All writes are
    // protected by admin-only rules. Sensitive data (bank details, ID numbers)
    // is only written server-side via the Admin SDK after Zod validation.
    match /employees/{employeeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /fieldOfficers/{officerId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /sites/{siteId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clientLocations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clientUsers/{mappingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /clientUsersByUid/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    match /workOrders/{workOrderId} {
      allow read: if isAdmin() || isFieldOfficer() || (
        isClientUser() &&
        exists(/databases/$(database)/documents/clientUsersByUid/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/clientUsersByUid/$(request.auth.uid)).data.clientId == resource.data.clientId
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isFieldOfficer();
    }

    // Attendance logs are created server-side only (Admin SDK). Reads are
    // restricted to authenticated users with an explicit role to prevent
    // cross-client or unauthenticated access to attendance data.
    match /attendanceLogs/{logId} {
      allow create: if false;
      allow read: if isAdmin() || isFieldOfficer() || isClientUser();
      allow update, delete: if isAdmin();
    }

    match /attendanceState/{employeeId} {
      allow read, write: if isAdmin();
    }

    match /systemMetrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /exportJobs/{jobId} {
      allow read, write: if isAdmin();
    }
  }
}
