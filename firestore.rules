rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helper functions ────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Guard: authenticated via synthetic email {phone}@guard.cisskerala.app
    // Guard clients sign in with Firebase Auth (email+PIN).
    // Guards have role == 'guard' in custom claims (set at PIN setup).
    function isGuard() {
      return isSignedIn() && (
        request.auth.token.role == 'guard' ||
        request.auth.token.email.matches('.*@guard\\.cisskerala\\.app')
      );
    }

    // Returns the employeeDocId claim for the signed-in guard (Firestore doc ID)
    function guardEmployeeDocId() {
      return request.auth.token.employeeDocId;
    }

    // Returns the employeeId claim (employee code, e.g. "CISS/TCS/2025-26/871")
    function guardEmployeeId() {
      return request.auth.token.employeeId;
    }

    // Returns the site ID the guard is currently assigned to (from custom claims)
    function guardAssignedSiteId() {
      return request.auth.token.assignedSiteId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'superAdmin' ||
        request.auth.token.email == 'admin@cisskerala.app'
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'superAdmin';
    }

    function isHR() {
      return isSignedIn() && request.auth.token.role == 'hr';
    }

    function isAccounts() {
      return isSignedIn() && request.auth.token.role == 'accounts';
    }

    function isCompliance() {
      return isSignedIn() && request.auth.token.role == 'compliance';
    }

    function isFieldOfficer() {
      return isSignedIn() && request.auth.token.role == 'fieldOfficer';
    }

    function isClientUser() {
      return isSignedIn() && request.auth.token.role == 'client';
    }

    // Returns the clientName claim for the signed-in client user (set at login via custom claims)
    function clientUserClientName() {
      return request.auth.token.clientName;
    }

    // ── Field-officer district helpers ──────────────────────────────────────
    // FO custom claims include assignedDistricts (array of district names).
    // Returns true if the FO is assigned to at least one of the given districts.

    function isFieldOfficerForDistrict(docDistrict) {
      return isFieldOfficer() &&
        request.auth.token.assignedDistricts != null &&
        docDistrict is string &&
        docDistrict in request.auth.token.assignedDistricts;
    }

    // Chained check for documents with a 'district' field
    function isFieldOfficerForDocDistrict() {
      return isFieldOfficerForDistrict(resource.data.district);
    }

    // ── Client-user scoping helpers ─────────────────────────────────────────

    // True when the document belongs to the signed-in client user's organization
    function isOwnClientDoc(clientFieldName) {
      return isClientUser() && clientUserClientName() != null &&
        resource.data[clientFieldName] is string &&
        resource.data[clientFieldName] == clientUserClientName();
    }

    // ── Resource field helpers ──────────────────────────────────────────────

    // True when the guard is assigned to a specific site (from resource data)
    function guardIsAssignedToResource() {
      return guardAssignedSiteId() != null &&
        resource.data.siteId == guardAssignedSiteId();
    }

    // Any staff role (not guard, not client)
    function isStaff() {
      return isAdmin() || isHR() || isAccounts() || isCompliance() || isFieldOfficer();
    }

    // ── users collection ────────────────────────────────────────────────────
    // Guards self-register here during PIN setup.
    // Staff read their own doc. Admin reads all.

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);

      // Guard can create their own user doc during PIN setup — field allowlist
      // prevents privilege-escalation attacks (role, admin, employeeId boundaries)
      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.keys().hasOnly([
          'uid', 'phone', 'displayName', 'email',
          'createdAt', 'updatedAt', 'setupComplete'
        ]);

      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid &&
        // Guards can only update safe fields — not role or employeeDocId
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'employeeDocId', 'employeeId', 'admin']));
      allow delete: if isAdmin();
    }

    // ── employees ───────────────────────────────────────────────────────────
    // Public profile access now goes through a server route backed by Admin SDK.
    // Raw employee docs are no longer anonymously readable.
    // Staff can read employee docs; guards can read only their own record;
    // client users can read employees for their mapped client.

    match /employees/{employeeId} {
      allow read: if isStaff() ||
        (isGuard() && (
          employeeId == guardEmployeeDocId() ||
          resource.data.employeeId == guardEmployeeId()
        )) ||
        isOwnClientDoc('clientName');
      allow create, update, delete: if isAdmin();
    }

    // ── clients / sites / clientLocations ───────────────────────────────────
    // Public enrollment and attendance must use scrubbed server routes.
    // Raw documents include coordinates and operational metadata — direct
    // Firestore reads are scoped by role:
    //   - Staff: full read (operational need)
    //   - Client user: only their own client documents
    //   - Guard: only their assigned site / client the site belongs to
    //   - No unauthenticated reads.

    match /clients/{clientId} {
      allow read: if isStaff() ||
        isOwnClientDoc('companyName') ||
        (isGuard() && guardAssignedSiteId() != null);
      allow create, update, delete: if isAdmin();
    }

    match /sites/{siteId} {
      allow read: if isStaff() ||
        isOwnClientDoc('clientName') ||
        (isGuard() && resource.data.siteId == guardAssignedSiteId());
      allow create, update, delete: if isAdmin();
    }

    match /clientLocations/{locationId} {
      allow read: if isStaff() ||
        isOwnClientDoc('clientName') ||
        (isGuard() && guardAssignedSiteId() != null);
      allow create, update, delete: if isAdmin();
    }

    // ── fieldOfficers ────────────────────────────────────────────────────────

    match /fieldOfficers/{officerId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // ── clientUsers / clientUsersByUid ───────────────────────────────────────

    match /clientUsers/{mappingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /clientUsersByUid/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    // ── workOrders ───────────────────────────────────────────────────────────
    // FO can read/update only workOrders in their assigned districts.
    // Client users see only their own client's workOrders.
    // Admin has full access.

    match /workOrders/{workOrderId} {
      allow read: if isAdmin() ||
        isFieldOfficerForDistrict(resource.data.district) ||
        isOwnClientDoc('clientName');
      allow create, delete: if isAdmin();
      // FO can update workOrders only in their assigned districts
      allow update: if isAdmin() ||
        (isFieldOfficer() &&
          resource.data.district in request.auth.token.assignedDistricts);
    }

    // ── fcmTokens (push notification device registration) ────────────────────
    // Any authenticated user can write their own FCM token records.
    // Admins can read all tokens (for targeted push notifications).

    match /fcmTokens/{tokenId} {
      allow read: if isAdmin();
      allow write: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.token is string &&
        request.resource.data.platform is string;
    }

    // ── attendanceLogs ───────────────────────────────────────────────────────
    // Guards create their own logs directly from their device.
    // Next.js Admin SDK still creates logs server-side — both are supported.
    // Guards can ONLY read and create their OWN logs (scoped by employeeDocId).
    // They CANNOT update or delete any log (immutable audit trail).

    match /attendanceLogs/{logId} {
      // Guards can create their own attendance records.
      // Guard client writes: status ('In'/'Out'), employeeDocId, reportedAt (server ts)
      allow create: if isGuard() &&
        request.resource.data.employeeDocId == guardEmployeeDocId() &&
        request.resource.data.status in ['In', 'Out'] &&
        request.resource.data.keys().hasAll(['employeeDocId', 'status', 'reportedAt']);

      // Guards can only read their own logs; FO scoped by district; client users scoped to their clientName
      allow read: if isAdmin() ||
        isFieldOfficerForDistrict(resource.data.district) ||
        isOwnClientDoc('clientName') ||
        isOwnClientDoc('siteClientName') ||
        isOwnClientDoc('employeeClientName') ||
        (isGuard() && resource.data.employeeDocId == guardEmployeeDocId());

      // Only admins can modify or delete logs (audit integrity)
      allow update, delete: if isAdmin();
    }

    // attendanceState — hot doc per guard tracking last check-in status, shift, duty point
    // This is the active collection used by the submit route and employee lookup API.
    match /attendanceState/{employeeId} {
      allow read: if isAdmin() || (isGuard() && guardEmployeeDocId() == employeeId);
      allow create, update: if isAdmin() || (isGuard() && guardEmployeeDocId() == employeeId);
      allow delete: if isAdmin();
    }

    // attendanceSessions — durable IN/OUT pairing used to close the exact
    // open duty session even if roster, shift, or duty point metadata changes.
    match /attendanceSessions/{sessionId} {
      allow read: if isStaff() ||
        (isGuard() && resource.data.employeeDocId == guardEmployeeDocId());
      allow create, update, delete: if isAdmin();
    }

    // Legacy plural collection — retained for backwards-compatibility only
    match /attendanceStates/{employeeId} {
      allow read: if isAdmin() || (isGuard() && guardEmployeeDocId() == employeeId);
      allow create, update: if isAdmin() || (isGuard() && guardEmployeeDocId() == employeeId);
      allow delete: if isAdmin();
    }

    // ── payrollEntries ───────────────────────────────────────────────────────
    // Guards can read their own payslips. Accounts/Admin write all.

    match /payrollEntries/{entryId} {
      // Guards can read their own payslips — matched by either Firestore doc ID or employee code
      allow read: if isAdmin() || isAccounts() || isHR() ||
        (isGuard() && (
          resource.data.employeeDocId == guardEmployeeDocId() ||
          resource.data.employeeId == guardEmployeeId()
        ));
      allow create, update, delete: if isAdmin() || isAccounts();
    }

    // ── Training & Evaluation ────────────────────────────────────────────────

    match /trainingModules/{moduleId} {
      // Guards and all signed-in users can read training modules
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /questionBanks/{bankId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /questions/{questionId} {
        // Signed-in read is fine; clients get scrubbed versions via server anyway.
        // Admin manages content.
        allow read: if isAdmin() || isFieldOfficer();
        allow create, update, delete: if isAdmin();
      }
    }

    match /quizAttempts/{attemptId} {
      allow read: if isAdmin() || isFieldOfficer() ||
        (isGuard() && resource.data.employeeDocId == guardEmployeeDocId());
      // Guards submit via server route (admin SDK bypasses rules). Lock down client writes.
      allow create, update, delete: if isAdmin();
    }

    match /trainingAssignments/{assignmentId} {
      // Guards can read their own training assignments and update progress
      allow read: if isAdmin() || isFieldOfficer() ||
        (isGuard() && resource.data.employeeDocId == guardEmployeeDocId());

      // Guards can update their own assignment progress (progressPercent, status, completedAt)
      allow update: if isAdmin() ||
        (isGuard() &&
          resource.data.employeeDocId == guardEmployeeDocId() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['progressPercent', 'status', 'startedAt', 'completedAt']));

      allow create, delete: if isAdmin();
    }

    // ── evaluations — FO can only evaluate employees in their assigned districts ──

    match /evaluations/{evalId} {
      allow read: if isAdmin() ||
        isFieldOfficerForDistrict(resource.data.district) ||
        (isGuard() && resource.data.employeeDocId == guardEmployeeDocId());

      // FO can create/update evaluations only for employees in their districts.
      // For creates where resource.data does not yet exist, validate the incoming document.
      allow create: if isAdmin() ||
        (isFieldOfficer() && request.resource.data.district in request.auth.token.assignedDistricts);

      allow update: if isAdmin() ||
        (isFieldOfficer() &&
          resource.data.district in request.auth.token.assignedDistricts &&
          request.resource.data.district in request.auth.token.assignedDistricts);

      allow delete: if isAdmin();
    }

    match /guardScores/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /awards/{awardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Payroll & Compliance (admin/accounts/HR only) ─────────────────────────

    match /complianceSettings/{docId} {
      allow read: if isAdmin() || isCompliance() || isHR() || isAccounts();
      allow write: if isAdmin() || isCompliance();
    }

    match /clientWageConfig/{configId} {
      allow read: if isAdmin() || isAccounts();
      allow write: if isAdmin() || isAccounts();
    }

    match /salaryStructures/{structureId} {
      allow read, write: if isAdmin() || isAccounts();
    }

    match /employeeSalaries/{salaryId} {
      allow read, write: if isAdmin() || isAccounts();
    }

    match /payrollCycles/{runId} {
      allow read: if isAdmin() || isAccounts() || isHR();
      allow write: if isAdmin() || isAccounts();
    }

    // ── System & internal ───────────────────────────────────────────────────

    match /systemMetrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /exportJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    // ── workOrderTodos (task management for work orders) ─────────────────────

    match /workOrderTodos/{todoId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── notifications (push + web) ─────────────────────────────────────────

    match /notifications/{notifId} {
      // Each user can read their own notifications
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.recipientUid == request.auth.uid);
      allow create: if isAdmin() || isFieldOfficer();
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.recipientUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']));
      allow delete: if isAdmin();
    }

    // ── resetOtps (PIN recovery) ───────────────────────────────────────────
    // Store OTP codes for guard PIN reset - admin only writes, user reads own

    match /resetOtps/{otpId} {
      allow read: if isSignedIn() && resource.data.phone == request.auth.token.phone;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── branches / districts / states (multi-state scaffold) ───────────────

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /districts/{districtId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAdmin();
    }

    match /states/{stateId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /regions/{regionId} {
      allow read, write: if isSuperAdmin();
    }

    match /regionOnboardingAudit/{auditId} {
      allow read, write: if isSuperAdmin();
    }

    match /systemConfig/{docId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Server-only collections (Admin SDK only — explicit client deny) ─────
    // These collections are only accessed via server-side Admin SDK routes.
    // Explicit deny ensures no client can ever read or write them directly.

    match /foVisitReports/{docId} {
      allow read, write: if false;
    }

    match /foTrainingReports/{docId} {
      allow read, write: if false;
    }

    match /branchExpenses/{docId} {
      allow read, write: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /regionConnections/{docId} {
      allow read, write: if false;
    }

    match /roleClaimRepairAudit/{docId} {
      allow read, write: if false;
    }

    match /clientUserAudit/{docId} {
      allow read, write: if false;
    }

    match /fieldOfficerAudit/{docId} {
      allow read, write: if false;
    }

    // ── guardLocations — live GPS tracking heartbeat ─────────────────────────
    // Guards write their own location doc (employeeId == doc ID).
    // Read is scoped per role: admin/staff full read, FO by district,
    // client by own client, guard only own location.

    match /guardLocations/{employeeId} {
      // Read scoped by role — NOT open to all signed-in users
      allow read: if isAdmin() ||
        // FO reads only guard locations in their assigned districts
        (isFieldOfficer() &&
          request.auth.token.assignedDistricts != null &&
          resource.data.district in request.auth.token.assignedDistricts) ||
        // Client user reads only their own guards
        (isClientUser() &&
          clientUserClientName() != null &&
          resource.data.clientName == clientUserClientName()) ||
        // Guard reads only their own location
        (isGuard() && guardEmployeeId() == employeeId);

      // Guards write their own location document, and staff can create/update
      // guard location records during QR attendance and monitoring workflows.
      allow create, update: if (isGuard() && guardEmployeeId() == employeeId) || isStaff();

      // Only the guard themselves or admin/staff can delete
      allow delete: if (isGuard() && guardEmployeeId() == employeeId) || isAdmin();
    }
  }
}
